{
  "name": "codify",
  "displayName": "Codify",
  "description": "A VS Code extension example",
  "version": "0.0.1",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codify.helloWorld"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codify.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "codify.search",
        "title": "Spotify: Search and Play"
      }
    ],
    "keybindings": [
      {
        "command": "spotify.playPause",
        "key": "ctrl+shift+p ctrl+shift+space",
        "mac": "cmd+shift+p cmd+shift+space"
      },
      {
        "command": "spotify.next",
        "key": "ctrl+shift+p ctrl+shift+right",
        "mac": "cmd+shift+p cmd+shift+right"
      },
      {
        "command": "spotify.previous",
        "key": "ctrl+shift+p ctrl+shift+left",
        "mac": "cmd+shift+p cmd+shift+left"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "crypto": "^1.0.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "open": "^11.0.0",
    "spotify-web-api-node": "^5.0.2"
  }
}
